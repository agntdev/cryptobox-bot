[
  {
    "name": "/pause pauses scheduled posts",
    "steps": [
      {
        "send": { "text": "/pause" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "⏸️ Scheduled posts paused."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "pause button tap pauses posts",
    "steps": [
      {
        "send": { "callback": "pause:do" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "⏸️ Scheduled posts paused."
            }
          }
        ]
      }
    ]
  }
]
