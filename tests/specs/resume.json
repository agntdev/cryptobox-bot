[
  {
    "name": "/resume resumes scheduled posts",
    "steps": [
      {
        "send": { "text": "/resume" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "▶️ Scheduled posts resumed."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "resume button tap resumes posts",
    "steps": [
      {
        "send": { "callback": "resume:do" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "▶️ Scheduled posts resumed."
            }
          }
        ]
      }
    ]
  }
]
